## 允许命令执行和文件访问的默认根目录
WORKSPACE_ROOT=.

## 额外允许访问的目录（逗号分隔，可选）
EXTRA_ALLOWED_ROOTS=

## 命令执行超时（秒）
COMMAND_TIMEOUT_SECONDS=30

## stdout/stderr 最大返回字符数
MAX_OUTPUT_CHARS=12000

## read_file 最大返回字符数
MAX_FILE_READ_CHARS=20000

## search_files 最大返回匹配条数
MAX_SEARCH_RESULTS=100

## 额外拦截的命令正则（逗号分隔，可选）
BLOCKED_COMMAND_PATTERNS=

## 命令解释器路径；留空时自动按系统选择
## macOS/Linux 默认 /bin/bash，Windows 默认 powershell.exe
COMMAND_EXECUTABLE=

## 是否打印模型输出
PRINT_MODEL_OUTPUT=true
